pipeline {
    agent any

    environment {
        IMAGE_NAME = 'my-go-service'
        IMAGE_TAG  = 'optimized'
    }

    stages {
        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('Cleanup Existing Image') {
            steps {
                echo "Checking if ${IMAGE_NAME}:${IMAGE_TAG} already exists..."
                script {
                    sh """
                        if docker image inspect ${IMAGE_NAME}:${IMAGE_TAG} >/dev/null 2>&1; then
                            echo "Old image found. Removing to prevent conflicts..."
                            docker rmi -f ${IMAGE_NAME}:${IMAGE_TAG}
                        else
                            echo "No conflicting image found. Proceeding cleanly."
                        fi
                    """
                }
            }
        }

        stage('Build Optimized Image') {
            steps {
                echo "Executing Multi-Stage Build for ${IMAGE_NAME}:${IMAGE_TAG}..."
                // Fixed: Tells Docker to look inside the Project2 subfolder for both the Dockerfile and code context
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -f Project2/Dockerfile Project2/"
            }
        }

        stage('Verify Size Metric') {
            steps {
                echo 'Checking final container footprint...'
                script {
                    def imageSize = sh(script: "docker images --format '{{.Size}}' ${IMAGE_NAME}:${IMAGE_TAG}", returnStdout: true).trim()
                    echo "====================================================="
                    echo " SUCCESS: Enterprise Build Completed."
                    echo " Target Image Production Size: ${imageSize}"
                    echo "====================================================="
                }
            }
        }
    }

    post {
        always {
            // Fixed: Wrapped in a node block to guarantee it runs smoothly even if early stages fail
            node {
                echo 'Cleaning up intermediate transient build cache and dangling layers...'
                sh 'docker image prune -f'
            }
        }
    }
}
